│   │   ├── extractor.py           # 1.2 Pipeline de extração (ticks + OHLC)
│   │   ├── storage.py             # 1.3 Armazenamento Parquet
│   │   ├── cleaner.py             # 1.4 Limpeza de dados (bad ticks, lacunas)
