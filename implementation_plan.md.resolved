│   │   └── bet_sizing.py          # 4.4 Kelly fracionário
│   ├── backtest/                  # Fase 5 — Backtesting
│   │   ├── __init__.py
│   │   ├── cpcv.py                # 5.1 Combinatorial Purged CV
│   │   ├── cost_model.py          # 5.2 Modelagem de custos
│   │   ├── metrics.py             # 5.3 Métricas (Sharpe Deflacionado, etc.)
│   │   └── attribution.py         # 5.4 Análise de atribuição
│   └── execution/                 # Fase 6 — Live Trading
│       ├── __init__.py
│       ├── engine.py              # 6.1 Engine assíncrona
│       ├── order_manager.py       # 6.2 Gerenciador de ordens
│       ├── risk.py                # 6.3 Circuit breakers
│       └── audit.py               # 6.4 Auditoria e logging
├── tests/                         # Testes unitários por fase
│   ├── __init__.py
│   ├── test_data/
│   ├── test_features/
│   ├── test_labeling/
